# ═══════════════════════════════════════════════════════════════
# Cashflow Survival Agent — Frontend Environment
# ═══════════════════════════════════════════════════════════════
# Copy to .env.local:  cp .env.local.example .env.local
#
# SECURITY: Variables WITHOUT "NEXT_PUBLIC_" prefix are SERVER-SIDE ONLY
# and are NEVER exposed to the browser bundle.

# Stellar private key for x402 agent signing (SERVER-SIDE ONLY)
# Generate at: https://laboratory.stellar.org/#account-creator?network=test
STELLAR_PRIVATE_KEY=S...your-agent-secret-key...

# Backend URL (server-side proxy target)
BACKEND_URL=http://localhost:4000

# Public vars (safe to expose to browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
