# ═══════════════════════════════════════════════════════
# Cashflow Survival Agent — Stellar Testnet Configuration
# ═══════════════════════════════════════════════════════

# Server wallet — receives payments (API provider)
# Generate at: https://laboratory.stellar.org/#account-creator?network=test
PAY_TO_ADDRESS=G...your-public-key...
PAY_TO_SECRET=S...your-secret-key...

# Server port
PORT=4000

# Client agent wallet — spends USDC for API access
# This must be a DIFFERENT keypair from the server wallet
# Generate at: https://laboratory.stellar.org/#account-creator?network=test
STELLAR_PRIVATE_KEY=S...your-secret-key...
